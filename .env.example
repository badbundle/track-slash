# Host port published for the Postgres container.
# Default is 5432. Override in a local `.env` (gitignored) when the
# canonical port collides with another Postgres on your machine.
POSTGRES_PORT=5432

# Object storage defaults. Local development stores bytes under gitignored tmp/.
TRACK_SLASH_STORAGE_BACKEND=local
TRACK_SLASH_STORAGE_LOCAL_ROOT=tmp/storage
TRACK_SLASH_STORAGE_BUCKET=local
TRACK_SLASH_STORAGE_MAX_UPLOAD_BYTES=52428800
