# Host port published for the Postgres container.
# Default is 5432. Override in a local `.env` (gitignored) when the
# canonical port collides with another Postgres on your machine.
POSTGRES_PORT=5432

# Run embedded DB migrations during normal trackd startup. Production
# deployments with a separate migration job should set this to false.
TRACK_SLASH_AUTO_MIGRATE=true

# Public browser origin for passkeys in deployed environments.
# Production passkeys require HTTPS. Localhost development can omit this and
# use the request-derived localhost origin.
# TRACK_SLASH_PUBLIC_ORIGIN=https://track.example.com

# Object storage defaults. Local development stores bytes under gitignored tmp/.
TRACK_SLASH_STORAGE_BACKEND=local
TRACK_SLASH_STORAGE_LOCAL_ROOT=tmp/storage
TRACK_SLASH_STORAGE_BUCKET=local
TRACK_SLASH_STORAGE_MAX_UPLOAD_BYTES=52428800

# S3-compatible object storage, for example Garage.
# TRACK_SLASH_STORAGE_BACKEND=s3
# TRACK_SLASH_STORAGE_BUCKET=track-slash
# TRACK_SLASH_STORAGE_S3_ENDPOINT=http://garage:3900
# TRACK_SLASH_STORAGE_S3_REGION=us-east-1
# TRACK_SLASH_STORAGE_S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
